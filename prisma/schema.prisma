// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}




model Agent {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  role         String   @default("AGENT") // AGENT, ADMIN
  permissions  String   @default("all")   // Comma-separated: kassa,order,debt,product,crm,history,all
  orders       Order[]
  createdAt    DateTime @default(now())
}

model Client {
  id           String    @id @default(uuid())
  customId     String?   @unique // Mijoz ID-si, e.g., 3M1085
  name         String
  phone        String?   // Telefon raqami
  address      String?   // Manzil
  creditLimit  Float     @default(10000) // Default in USD
  currentDebt  Float     @default(0)    // In USD
  status       String    @default("ACTIVE") // ACTIVE, BLACKLIST
  telegramGroupId  String?
  telegramUserId   String?   // Telegram User ID (from bot start)
  telegramUsername String?   // Telegram Username (e.g., @user)
  orders       Order[]
  payments     Payment[]
  lateCount    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Product {
  id           String      @id @default(uuid())
  code         String?     @unique
  name         String
  group        String?
  guarantee    String?
  costPrice    Float       // Tannarx in USD
  sellPrice    Float       // Sotish narxi in USD
  stock        Int         @default(0)
  minStock     Int         @default(0)
  orderItems   OrderItem[]
}

model Order {
  id           String      @id @default(uuid())
  orderNumber  Int?        @unique // Buyurtma raqami
  clientId     String
  client       Client      @relation(fields: [clientId], references: [id])
  agentId      String
  agent        Agent       @relation(fields: [agentId], references: [id])
  driverPhone  String?     // Mashina telefon raqami
  amount       Float       // Top amount in USD
  status       String      @default("PENDING") // PENDING, CONFIRMED, FULFILLED, PAID, CANCELLED
  isDebt       Boolean     @default(false)
  approvedBy   String?     // Admin who approved
  approvedAt   DateTime?
  coordinates  String?
  paymentMethod String?    // USD, UZS, CARD, BANK
  due_date     DateTime?
  isLateProcessed Boolean @default(false)
  
  items        OrderItem[]
  
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model OrderItem {
  id           String   @id @default(uuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id])
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  quantity     Int
  price        Float    // Selling price per item
}

model Payment {
  id           String   @id @default(uuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id])
  orderId      String?  // Optional: link to a specific order
  amount       Float    // USD equivalent
  paymentMethod String  @default("USD") // USD, UZS, CARD, TRANSFER
  
  // Breakdown
  cashAmount     Float?   @default(0)
  terminalAmount Float?   @default(0)
  clickAmount    Float?   @default(0)
  bankAmount     Float?   @default(0)
  usdAmount      Float?   @default(0)
  changeAmount   Float?   @default(0)
  discountAmount Float?   @default(0)
  isConverted    Boolean? @default(true)

  originalAmount Float? // If paid in UZS, original amount might be 12,000,000
  exchangeRate   Float? 
  date         DateTime @default(now())
  notes        String?
  receiptUrl   String?  // Kvitansiya fayl manzili
  status       String   @default("WAITING_APPROVAL") // WAITING_APPROVAL, CONFIRMED, REJECTED
  approvedBy   String?
  approvedAt   DateTime?
}

model Log {
  id           String   @id @default(uuid())
  action       String   
  actorId      String?  
  actorRole    String?
  metadata     String?  
  timestamp    DateTime @default(now())
}

model Settings {
  id               String   @id @default("singleton")
  telegramToken    String?
  chatId1          String?
  chatId2          String?
  chatId3          String?
  templateKassa    String?  @default("Kassa xabari: @name, @cur_sum$")
  templateChek     String?  @default("Chek xabari: @name, @cur_sum$")
  templateQarz     String?  @default("Assalomu alaykum, hurmatli mijoz @name. Sizning eski qarzingiz mavjud: @cur_sum$. O‘tib ketgan muddati @days kun.")
  templateBirthday String?  @default("Tug'ilgan kuningiz bilan, @name!")
  exchangeRate     Float?    @default(12800)
  updatedAt        DateTime  @updatedAt
}
